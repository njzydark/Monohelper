{
  "packageManager": "pnpm",
  "lockFileDirectoryPath": "./",
  "dependencies": {
    "filter": {
      "exclude": {
        "common": [
          "react"
        ],
        "package": {
          "packages/foo": [
            "react-dom"
          ]
        }
      }
    },
    "lock": {
      "common": {
        "react": "16.14.0"
      },
      "package": {
        "packages/bar": {
          "react-dom": "17"
        }
      }
    }
  },
  "lockDependencies": {
    "all": {
      "react": "16.14.0"
    },
    "package": {
      "packages/bar": {
        "react-dom": "17"
      }
    }
  }
}